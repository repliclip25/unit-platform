# ─── UNIT Platform — Production Environment Template ──────────────────────────
# Copy to .env on the production server. Fill in all values marked <REQUIRED>.
# Never commit .env to git.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=UNIT
APP_ENV=production
APP_KEY=<REQUIRED: run `php artisan key:generate --show` on the server>
APP_DEBUG=false
APP_URL=https://unit.report

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning        # error | warning in prod — never debug

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=<REQUIRED: e.g. 127.0.0.1>
DB_PORT=3306
DB_DATABASE=<REQUIRED: e.g. unit_production>
DB_USERNAME=<REQUIRED>
DB_PASSWORD=<REQUIRED>

# ── Sessions ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true     # encrypt session data in prod
SESSION_PATH=/
SESSION_DOMAIN=unit.report
SESSION_SECURE_COOKIE=true

# ── Cache & Queue ─────────────────────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=<REQUIRED if Redis has auth>
REDIS_PORT=6379

# ── Mail (Namecheap SMTP) ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_ENCRYPTION=ssl
MAIL_HOST=premium105.web-hosting.com   # do NOT use mail.unit.report — SSL cert mismatch
MAIL_PORT=465
MAIL_USERNAME=hello@unit.report
MAIL_PASSWORD=<REQUIRED>
MAIL_FROM_ADDRESS=hello@unit.report
MAIL_FROM_NAME="UNIT"

# ── Stripe (LIVE keys — switch from test before launch) ───────────────────────
# Get live keys from: https://dashboard.stripe.com/apikeys
STRIPE_KEY=<REQUIRED: pk_live_...>
STRIPE_SECRET=<REQUIRED: sk_live_...>
STRIPE_WEBHOOK_SECRET=<REQUIRED: whsec_... from Stripe webhook dashboard>
# Webhook endpoint to register in Stripe: https://unit.report/stripe/webhook

# ── Gmail API ─────────────────────────────────────────────────────────────────
# Update authorized redirect URI in Google Cloud Console to production URL
GMAIL_CLIENT_ID=<REQUIRED>
GMAIL_CLIENT_SECRET=<REQUIRED>
GMAIL_REDIRECT_URI=https://unit.report/workers/ava/gmail/callback
GMAIL_REFRESH_TOKEN=<REQUIRED>
AVA_GMAIL_ADDRESS=<REQUIRED: the Gmail address for AVA>
GMAIL_PUBSUB_TOPIC=projects/unit-platform/topics/ava-gmail-inbox
# Also update the PubSub push subscription endpoint to: https://unit.report/gmail/webhook

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<REQUIRED>

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
